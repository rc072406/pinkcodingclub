---
// src/pages/curriculum.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="CURRICULUM // PINK CODING CLUB" isIndex={false} version="Curriculum // V.01">
  
  <link rel="stylesheet" href="/styles/manifesto.css" slot="head" />

  <span slot="hero-title">Lead The Culture</span>

  <div class="grid-section">
    <div class="grid-item vacuum-seal-container">
        <div class="plastic-wrap">
            <div class="archive-label">
                <p style="font-size: 0.6rem; font-weight: bold;">PCC_LOGISTICS // BACKEND AND APIs</p>
                <p style="font-size: 1.2rem; font-weight: 900; margin: 5px 0;">STATUS: ENCRYPTED</p>
                <p style="font-size: 0.6rem;">COMING SOON<br>DECRYPTING...</p>
                <span class="barcode">|||| || ||||| ||| || |||</span>
            </div>
        </div>
        <div class="grid-content-wrapper">
            <span class="code-snip">function deploy() &#123;</span>
            <h2>SYSTEM ARCHITECTURE</h2>
            <p>Mastering the backend of the future.</p>
        </div>
    </div>

    <div class="grid-item shatter-container">
        <div class="glass-shard-overlay">
            <div class="shatter-text">ACCESS GRANTED</div>
        </div>
        
        <div class="grid-content-wrapper" style="opacity: 0.8; filter: blur(1px);">
            <span class="code-snip">import &#123; GLAM &#125; from 'pcc';</span>
            <h2>CYBER STYLING</h2>
            <p>UI/UX design with a high-fashion lens.</p>
            
            <a href="webdesign.astro" class="view-btn">I'M AN ICON</a>
        </div>
    </div>
  </div>

</BaseLayout>
