---
// src/pages/webdesign.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import { webDesignLessons } from '../data/curriculum';
import LessonCard from '../components/LessonCard.astro';


---

<BaseLayout title="CURRICULUM // FASHION FORWARD">
   <div class="lesson-grid">
    {webDesignLessons.map((lesson) => (
      <div class="lesson-item">
        <div class="top-meta">
          <span class="lesson-meta">LEVEL // {lesson.step}</span>
          <h3>{lesson.title}</h3>
          <span class="view-btn" style="background: none; border-color: #333; color: #666; font-size: 0.5rem;">
            {lesson.focus}
          </span>
        </div>
        
        <p>{lesson.desc}</p>

        {!lesson.isLocked ? (
          <a href={lesson.href} class="view-btn" style="margin-top: 20px; text-align: center;">
            ENTER SECTION
          </a>
        ) : (
          <span class="view-btn" style="margin-top: 20px; opacity: 0.3; pointer-events: none; text-align: center;">
            STAY TUNED
          </span>
        )}
      </div>
    ))}
  </div>
</BaseLayout>
