---
// src/pages/webdesign.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import LessonCard from '../components/LessonCard.astro';
import { webDesignLessons } from '../data/curriculum';

---

<BaseLayout title="CURRICULUM // FASHION FORWARD" isIndex={false} version="Syllabus // V.01">
  
  <link rel="stylesheet" href="/styles/manifesto.css" slot="head" />
<style>
    .curriculum-hero {
        padding: 120px 4% 80px 4%;
        max-width: 1000px;
    }

    .lesson-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
        width: 100%;
        border-top: 1px solid var(--border-gray);
    }

    .project-cta {
        padding: 100px 4%;
        text-align: center;
        border-bottom: 1px solid var(--border-gray);
    }

    .gold-box {
        border: 2px solid #e41e81;
        padding: 60px 20px;
        max-width: 900px;
        margin: 0 auto;
    }

    @media (max-width: 768px) {
        .lesson-grid { grid-template-columns: 1fr; }
    }
</style>

  <section class="curriculum-hero">
    <p class="founder-stats">THE EXCLUSIVE P.C.C. PROGRAM</p>
    <h1 class="editorial-title">Fashion Forward<br>Responsive Web Design</h1>
    <p class="manifesto-snippet">
      A four-part journey designed for the girly-girl who refuses to choose between her aesthetic and her ambition. 
      Master the technical skills to bring your wildest dreams to life. Screw printing out "hello world." It's time to lead the culture. 
    </p>
    <a href="https://www.freecodecamp.org/learn/responsive-web-design-v9/" target="_blank" class="cta-btn" style="margin-top: 40px; display: inline-block;">
        ACCESS TEXTBOOK
    </a>
  </section>

  <div class="lesson-grid">
    {webDesignLessons.map((lesson) => (
      <LessonCard {...lesson} />
    ))}
  </div>

<section class="project-cta">
    <div class="gold-box shatter-container">
        <div class="glass-shard-overlay">
            <span class="shatter-text">UNLOCK CERTIFICATION</span>
        </div>
        <h2 style="font-family: 'Archivo Black'; font-size: 2.5rem; margin-bottom: 15px;">THE SHOWROOM</h2>
        <p style="text-transform: none; max-width: 600px; margin: 0 auto 30px auto; opacity: 0.9;">
          To earn the <strong>Fashion Forward Responsive Web Design Certificate</strong>, students must build a fully responsive, 
            multi-page personal lookbook and a product landing page that passes the P.C.C. Design & Logic Philosophy.
<a href="/certificate" target="_blank" class="cta-btn" style="margin-top: 40px;>
       CLAIM IT
    </a>
        </p>
       
    </div>
  </section>

</BaseLayout>
